{
  "name": "cookie-decliner",
  "version": "1.1.0",
  "description": "Manifest V3 browser extension that automatically declines cookie consent popups across major consent management frameworks (SourcePoint, TCF v2.0, Cookiebot, OneTrust, Usercentrics, Complianz, Didomi).",
  "main": "index.js",
  "homepage": "https://github.com/RuneVed/cookie-decliner#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/RuneVed/cookie-decliner.git"
  },
  "bugs": {
    "url": "https://github.com/RuneVed/cookie-decliner/issues"
  },
  "scripts": {
    "build": "npm run build:bundle",
    "build:types": "tsc --noEmit false --emitDeclarationOnly",
    "build:bundle": "esbuild src/content-script.ts --bundle --outfile=dist/content-script.js --format=iife --target=es2020 --platform=browser",
    "watch": "esbuild src/content-script.ts --bundle --outfile=dist/content-script.js --format=iife --target=es2020 --platform=browser --watch",
    "clean": "if exist dist rmdir /s /q dist",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "lint:check": "eslint src/**/*.ts --max-warnings 0",
    "prebuild": "npm run lint:check",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:coverage:open": "jest --coverage && npm run open:coverage",
    "test:all": "npm run test && npx playwright test",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:debug": "npx playwright test --debug",
    "open:coverage": "if (Test-Path coverage/lcov-report/index.html) { Start-Process coverage/lcov-report/index.html }",
    "icons": "node scripts/convert-icons.js",
    "package": "node scripts/package.js",
    "package:chrome": "node scripts/package-chrome.js",
    "package:source": "node scripts/package-source.js"
  },
  "keywords": [
    "cookie",
    "consent",
    "privacy",
    "gdpr",
    "didomi",
    "tcf",
    "onetrust",
    "cookiebot",
    "browser-extension",
    "manifest-v3"
  ],
  "author": "RuneVed <runevu@proton.me>",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.49.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@types/chrome": "^0.1.1",
    "@types/jest": "^29.5.14",
    "archiver": "^7.0.1",
    "esbuild": "^0.25.8",
    "eslint": "^9.32.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.2.5",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.18.0"
  }
}
